# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly declare common web/JS/TS file types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf

# Binary files — don't touch line endings
*.png  binary
*.jpg  binary
*.ico  binary
*.woff binary
*.woff2 binary
